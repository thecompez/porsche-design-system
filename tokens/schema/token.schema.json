{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PDS native design tokens",
  "type": "object",
  "required": ["tokens"],
  "properties": {
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "type", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
          "category": {
            "enum": ["blur", "breakpoint", "color", "gradient", "motion", "radius", "shadow", "spacing", "typography"]
          },
          "type": { "enum": ["color", "number", "duration", "fontFamily", "fontWeight", "easing", "string"] },
          "value": {},
          "alias": { "type": "string" },
          "light": {},
          "dark": {},
          "highContrast": {},
          "density": { "type": "object" },
          "platform": { "type": "object" },
          "description": { "type": "string", "minLength": 1 },
          "classification": {
            "enum": ["Extracted", "Derived", "PlatformAdapted", "Unavailable"]
          },
          "upstreamSource": { "type": "string", "minLength": 1 },
          "upstreamValue": {},
          "deprecated": {
            "type": "object",
            "required": ["message"],
            "properties": {
              "message": { "type": "string" },
              "replacement": { "type": "string" }
            }
          }
        },
        "oneOf": [
          { "required": ["value"] },
          { "required": ["alias"] },
          { "required": ["light", "dark"] }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
